{
  "name": "llm-latency-dashboard",
  "version": "0.1.0",
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.9.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.81.1"
  },
  "description": "Client-only dashboard measuring LLM response latency (total, TTFT, tok/s) by hour of day. Keys stay in the browser.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "deploy": "bun run build && wrangler pages deploy .svelte-kit/cloudflare --project-name=llm-latency"
  },
  "type": "module"
}
